# Justice Dev Starter Kit Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Authentication (Cognito — alternative to Clerk)
# COGNITO_USER_POOL_ID=us-east-1_xxx
# COGNITO_CLIENT_ID=xxx
# COGNITO_CLIENT_SECRET=xxx

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID_FREE=price_xxx
STRIPE_PRICE_ID_STARTER=price_xxx
STRIPE_PRICE_ID_PRO=price_xxx

# AI Integration
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4
AI_MAX_TOKENS=4096
AI_REQUIRE_CITATIONS=true

# Document Generation
DOCUMENT_TEMPLATE_DIR=./templates
DOCUMENT_OUTPUT_DIR=./generated

# Encrypted Storage
STORAGE_PROVIDER=local
STORAGE_ENCRYPTION_KEY=your-256-bit-key-here
AWS_S3_BUCKET=justice-evidence-vault
AWS_REGION=us-east-1

# Database
DATABASE_URL=postgresql://localhost:5432/justice_app

# Audit Logging
AUDIT_LOG_LEVEL=info
AUDIT_RETENTION_DAYS=365

# Security
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
